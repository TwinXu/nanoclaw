#!/usr/bin/env node
// dingtalk-wiki — CLI tool to read and write DingTalk wiki / knowledge base content
// Uses v2.0 wiki API for workspaces/nodes, v1.0 doc API for document content
// No npm dependencies; uses built-in fetch (Node 18+)

const DINGTALK_APP_KEY = process.env.DINGTALK_APP_KEY;
const DINGTALK_APP_SECRET = process.env.DINGTALK_APP_SECRET;

const BASE = 'https://api.dingtalk.com';
const OAPI_BASE = 'https://oapi.dingtalk.com';

// ─── Auth ────────────────────────────────────────────────────────────

let _tokenCache = null;

async function getAccessToken() {
  if (_tokenCache && Date.now() < _tokenCache.expiresAt) {
    return _tokenCache.token;
  }
  if (!DINGTALK_APP_KEY || !DINGTALK_APP_SECRET) {
    fatal('DINGTALK_APP_KEY and DINGTALK_APP_SECRET must be set');
  }
  const res = await fetch(`${BASE}/v1.0/oauth2/accessToken`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      appKey: DINGTALK_APP_KEY,
      appSecret: DINGTALK_APP_SECRET,
    }),
  });
  const data = await res.json();
  if (!data.accessToken) {
    fatal(`Auth failed: ${JSON.stringify(data)}`);
  }
  _tokenCache = {
    token: data.accessToken,
    expiresAt: Date.now() + (data.expireIn - 60) * 1000,
  };
  return _tokenCache.token;
}

// ─── Operator ID (auto-resolve from admin) ──────────────────────────

let _operatorIdCache = null;

async function getOperatorId() {
  if (_operatorIdCache) return _operatorIdCache;

  const token = await getAccessToken();

  // Step 1: Get admin list → find primary admin (sys_level=1)
  const adminRes = await fetch(
    `${OAPI_BASE}/topapi/user/listadmin?access_token=${token}`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({}),
    },
  );
  const adminData = await adminRes.json();
  if (adminData.errcode && adminData.errcode !== 0) {
    fatal(`Failed to get admin list: ${adminData.errmsg}`);
  }
  const admins = adminData.result || [];
  const admin = admins.find((a) => a.sys_level === 1) || admins[0];
  if (!admin) {
    fatal('No admin found in organization');
  }

  // Step 2: Get user detail → extract unionId
  const userRes = await fetch(
    `${OAPI_BASE}/topapi/v2/user/get?access_token=${token}`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userid: admin.userid }),
    },
  );
  const userData = await userRes.json();
  if (userData.errcode && userData.errcode !== 0) {
    fatal(`Failed to get user detail: ${userData.errmsg}`);
  }
  const unionId = userData.result?.unionid;
  if (!unionId) {
    fatal(`No unionId found for admin user ${admin.userid}`);
  }

  _operatorIdCache = unionId;
  return unionId;
}

// ─── HTTP helpers ────────────────────────────────────────────────────

async function api(path, opts = {}) {
  const token = await getAccessToken();
  const url = path.startsWith('http') ? path : `${BASE}${path}`;
  const res = await fetch(url, {
    ...opts,
    headers: {
      'x-acs-dingtalk-access-token': token,
      'Content-Type': 'application/json',
      ...opts.headers,
    },
  });
  if (!res.ok) {
    const text = await res.text();
    fatal(`API error (${res.status}): ${text}\n  ${path}`);
  }
  const data = await res.json();
  return data;
}

// ─── URL / token parsing ─────────────────────────────────────────────

function parseUrlOrToken(input) {
  // URL formats:
  //   https://alidocs.dingtalk.com/i/nodes/ABC123
  //   https://alidocs.dingtalk.com/i/spaces/ABC123/nodes/DEF456
  //   Plain token: ABC123
  const nodeMatch = input.match(
    /alidocs\.dingtalk\.com\/i\/(?:spaces\/[A-Za-z0-9]+\/)?nodes\/([A-Za-z0-9]+)/,
  );
  if (nodeMatch) return { nodeId: nodeMatch[1] };

  const spaceMatch = input.match(
    /alidocs\.dingtalk\.com\/i\/spaces\/([A-Za-z0-9]+)/,
  );
  if (spaceMatch) return { spaceId: spaceMatch[1] };

  // Bare token
  if (/^[A-Za-z0-9_-]+$/.test(input)) return { nodeId: input };
  fatal(`Cannot parse token from: ${input}`);
}

// ─── API wrappers (v2.0 wiki) ───────────────────────────────────────

async function listWorkspaces() {
  const operatorId = await getOperatorId();
  const items = [];
  let nextToken = undefined;
  do {
    const params = new URLSearchParams({
      maxResults: '50',
      orderBy: 'VIEW_TIME_DESC',
      withPermissionRole: 'false',
      operatorId,
    });
    if (nextToken) params.set('nextToken', nextToken);
    const data = await api(`/v2.0/wiki/workspaces?${params}`);
    if (data.workspaces) items.push(...data.workspaces);
    if (data.items) items.push(...data.items);
    nextToken = data.nextToken || undefined;
  } while (nextToken);

  if (!items.length) {
    console.log('No workspaces found.');
    return;
  }
  console.log('Workspaces:\n');
  for (const w of items) {
    console.log(`  ${w.name}`);
    console.log(`    ID: ${w.workspaceId}`);
    if (w.rootNodeId) console.log(`    Root Node: ${w.rootNodeId}`);
    if (w.url) console.log(`    URL: ${w.url}`);
    console.log();
  }
}

async function listNodes(parentNodeId) {
  const operatorId = await getOperatorId();
  const items = [];
  let nextToken = undefined;
  do {
    const params = new URLSearchParams({
      parentNodeId,
      maxResults: '50',
      withPermissionRole: 'false',
      operatorId,
    });
    if (nextToken) params.set('nextToken', nextToken);
    const data = await api(`/v2.0/wiki/nodes?${params}`);
    if (data.nodes) items.push(...data.nodes);
    if (data.items) items.push(...data.items);
    nextToken = data.nextToken || undefined;
  } while (nextToken);

  if (!items.length) {
    console.log('No nodes found.');
    return;
  }
  console.log(`Nodes under ${parentNodeId}:\n`);
  for (const n of items) {
    const category = n.category || n.type || 'unknown';
    console.log(`  ${n.name} [${category}]`);
    console.log(`    Node ID: ${n.nodeId}`);
    if (n.workspaceId) console.log(`    Workspace: ${n.workspaceId}`);
    if (n.hasChildren) console.log(`    Has children: yes`);
    if (n.url) console.log(`    URL: ${n.url}`);
    console.log();
  }
}

async function getNode(nodeId) {
  const operatorId = await getOperatorId();
  const params = new URLSearchParams({
    withPermissionRole: 'false',
    operatorId,
  });
  const data = await api(`/v2.0/wiki/nodes/${nodeId}?${params}`);
  const n = data.node || data;
  console.log(`Node: ${n.name}`);
  if (n.category) console.log(`  Category: ${n.category}`);
  if (n.type) console.log(`  Type: ${n.type}`);
  console.log(`  Node ID: ${n.nodeId}`);
  if (n.workspaceId) console.log(`  Workspace ID: ${n.workspaceId}`);
  if (n.hasChildren) console.log(`  Has children: yes`);
  if (n.url) console.log(`  URL: ${n.url}`);
  if (n.creatorId) console.log(`  Creator: ${n.creatorId}`);
  if (n.modifiedTime) console.log(`  Modified: ${n.modifiedTime}`);
}

async function readDocument(nodeId) {
  // Get node info from v2.0 to determine type
  const operatorId = await getOperatorId();
  const params = new URLSearchParams({
    withPermissionRole: 'false',
    operatorId,
  });
  const nodeData = await api(`/v2.0/wiki/nodes/${nodeId}?${params}`);
  const node = nodeData.node || nodeData;
  const docKey = node.docKey || node.nodeId || nodeId;
  const category = (node.category || '').toUpperCase();

  // Non-ALIDOC files (PDF, Word, images, etc.) → download instead
  if (NON_DOC_CATEGORIES.has(category)) {
    console.log(`Node "${node.name}" is a file [${category}], downloading...`);
    await downloadFile(nodeId, '.');
    return;
  }

  if (category === 'ALIDOC_SHEET') {
    await readSheet(docKey);
    return;
  }

  // Read document body blocks via v1.0 doc API
  const blocks = [];
  let nextToken = undefined;
  do {
    const blockParams = new URLSearchParams({ maxResults: '100' });
    if (nextToken) blockParams.set('nextToken', nextToken);
    const data = await api(
      `/v1.0/doc/documents/${docKey}/blocks?${blockParams}`,
    );
    if (data.children) blocks.push(...data.children);
    nextToken = data.nextToken || undefined;
  } while (nextToken);

  if (!blocks.length) {
    // Fallback: try the raw content endpoint
    try {
      const raw = await api(`/v1.0/doc/documents/${docKey}`);
      if (raw.body?.content) {
        console.log(raw.body.content);
        return;
      }
    } catch {
      // ignore fallback failure
    }
    console.log('(empty document)');
    return;
  }

  // Convert blocks to plain text
  const text = blocksToText(blocks);
  console.log(text);
}

function blocksToText(blocks, indent = '') {
  const lines = [];
  for (const block of blocks) {
    const type = block.type || '';
    const body = block.body || {};

    if (type === 'paragraph' || type === 'text') {
      const text = extractText(body);
      if (text) lines.push(indent + text);
    } else if (type === 'heading' || type.startsWith('heading')) {
      const level = block.level || parseInt(type.replace(/\D/g, '')) || 1;
      const text = extractText(body);
      if (text) lines.push(indent + '#'.repeat(level) + ' ' + text);
    } else if (type === 'bulletList' || type === 'bullet_list') {
      const text = extractText(body);
      if (text) lines.push(indent + '- ' + text);
      if (block.children) {
        lines.push(blocksToText(block.children, indent + '  '));
      }
    } else if (type === 'orderedList' || type === 'ordered_list') {
      const text = extractText(body);
      if (text) lines.push(indent + '1. ' + text);
      if (block.children) {
        lines.push(blocksToText(block.children, indent + '  '));
      }
    } else if (type === 'codeBlock' || type === 'code_block') {
      const text = extractText(body);
      if (text) {
        lines.push(indent + '```');
        lines.push(indent + text);
        lines.push(indent + '```');
      }
    } else if (type === 'table') {
      // Tables: render as TSV
      if (block.children) {
        for (const row of block.children) {
          if (row.children) {
            const cells = row.children.map((cell) => extractText(cell.body || {}));
            lines.push(indent + cells.join('\t'));
          }
        }
      }
    } else {
      // Generic: extract any text content
      const text = extractText(body);
      if (text) lines.push(indent + text);
      if (block.children) {
        lines.push(blocksToText(block.children, indent));
      }
    }
  }
  return lines.filter(Boolean).join('\n');
}

function extractText(body) {
  if (!body) return '';
  // body.text is the simplest case
  if (typeof body.text === 'string') return body.text;
  // body.content may be an array of inline elements
  if (Array.isArray(body.content)) {
    return body.content
      .map((c) => {
        if (typeof c === 'string') return c;
        if (c.text) return c.text;
        if (c.content) return extractText(c);
        return '';
      })
      .join('');
  }
  // body may have a nested body
  if (body.body) return extractText(body.body);
  return '';
}

const MAX_SHEET_ROWS = 1000;

function colToLetter(col) {
  let s = '';
  while (col > 0) {
    col--;
    s = String.fromCharCode(65 + (col % 26)) + s;
    col = Math.floor(col / 26);
  }
  return s;
}

async function readSheet(docKey) {
  // Get sheet metadata via v1.0 doc API
  const meta = await api(`/v1.0/doc/documents/${docKey}/sheets`);
  const sheets = meta.sheets || meta.items || [];

  if (!sheets.length) {
    console.log('(empty spreadsheet)');
    return;
  }

  for (let i = 0; i < sheets.length; i++) {
    const sheet = sheets[i];
    const sheetId = sheet.id || sheet.sheetId;
    const title = sheet.name || sheet.title || `Sheet ${i + 1}`;

    if (sheets.length > 1) {
      console.log(`--- Sheet: ${title} ---\n`);
    }

    const rowCount = sheet.rowCount || MAX_SHEET_ROWS;
    const columnCount = sheet.columnCount || 26;
    const readRows = Math.min(rowCount, MAX_SHEET_ROWS);
    const endCol = colToLetter(columnCount);
    const range = `A1:${endCol}${readRows}`;

    try {
      const result = await api(
        `/v1.0/doc/documents/${docKey}/sheets/${sheetId}/ranges/${range}`,
      );

      const rows = result.values || [];
      for (const row of rows) {
        const cells = Array.isArray(row)
          ? row.map((c) =>
              c == null ? '' : String(c).replace(/[\t\r\n]+/g, ' '),
            )
          : [];
        console.log(cells.join('\t'));
      }

      if (rowCount > MAX_SHEET_ROWS) {
        console.log(
          `\n... (${rowCount - MAX_SHEET_ROWS} more rows truncated)`,
        );
      }
    } catch (err) {
      console.log(`(failed to read sheet: ${err.message})`);
    }

    if (i < sheets.length - 1) console.log();
  }
}

// ─── File download (v2.0 storage API) ────────────────────────────────

const NON_DOC_CATEGORIES = new Set([
  'DOCUMENT', 'IMAGE', 'VIDEO', 'AUDIO', 'ARCHIVE', 'OTHER',
]);

async function downloadFile(nodeId, outputDir) {
  const operatorId = await getOperatorId();
  const params = new URLSearchParams({
    withPermissionRole: 'false',
    operatorId,
  });
  const nodeData = await api(`/v2.0/wiki/nodes/${nodeId}?${params}`);
  const node = nodeData.node || nodeData;
  const category = node.category || '';
  const fileName = node.name || `download-${nodeId}`;
  const ext = node.extension ? `.${node.extension}` : '';
  const fullName = ext && !fileName.endsWith(ext) ? fileName + ext : fileName;

  // Bridge: convert wiki nodeId (dentryUuid) → storage spaceId + dentryId
  // Wiki workspaceId != storage spaceId, so we must resolve via doc_2_0 API
  const dentryInfo = await api(
    `/v2.0/doc/dentries/${nodeId}/queryDentryId?operatorId=${operatorId}`,
  );
  const spaceId = dentryInfo.spaceId;
  const dentryId = dentryInfo.dentryId;

  if (!spaceId || !dentryId) {
    fatal(`Cannot resolve storage IDs for node ${nodeId}:\n${JSON.stringify(dentryInfo, null, 2)}`);
  }

  // Get download info via v1.0 storage API (download only exists in storage_1_0)
  const dlData = await api(
    `/v1.0/storage/spaces/${spaceId}/dentries/${dentryId}/downloadInfos/query?unionId=${operatorId}`,
    { method: 'POST', body: JSON.stringify({}) },
  );

  const sigInfo = dlData.headerSignatureInfo || {};
  const resourceUrls = sigInfo.resourceUrls || [];
  const resourceUrl = resourceUrls[0];
  if (!resourceUrl) {
    fatal(`No download URL returned for node ${nodeId}:\n${JSON.stringify(dlData, null, 2)}`);
  }

  // Build download headers from response
  const dlHeaders = {};
  if (sigInfo.headers) {
    for (const [k, v] of Object.entries(sigInfo.headers)) {
      dlHeaders[k] = v;
    }
  }

  // Download the file
  const dlRes = await fetch(resourceUrl, { headers: dlHeaders });
  if (!dlRes.ok) {
    fatal(`Download failed (${dlRes.status}): ${await dlRes.text()}`);
  }

  const fs = await import('fs');
  const path = await import('path');
  const destDir = outputDir || '.';
  fs.mkdirSync(destDir, { recursive: true });
  const destPath = path.join(destDir, fullName);
  const buffer = Buffer.from(await dlRes.arrayBuffer());
  fs.writeFileSync(destPath, buffer);

  console.log(`Downloaded: ${destPath}`);
  console.log(`  Size: ${buffer.length} bytes`);
  console.log(`  Category: ${category}`);
}

// ─── Upload file to wiki (v2.0 storage API) ─────────────────────────

async function uploadFile(parentNodeId, filePath) {
  const fs = await import('fs');
  const path = await import('path');

  if (!fs.existsSync(filePath)) {
    fatal(`File not found: ${filePath}`);
  }

  const operatorId = await getOperatorId();
  const fileName = path.basename(filePath);
  const fileSize = fs.statSync(filePath).size;

  // Resolve parent node → storage spaceId + dentryId
  const dentryInfo = await api(
    `/v2.0/doc/dentries/${parentNodeId}/queryDentryId?operatorId=${operatorId}`,
  );
  const spaceId = dentryInfo.spaceId;
  const parentDentryId = dentryInfo.dentryId;
  if (!spaceId || !parentDentryId) {
    fatal(`Cannot resolve storage IDs for node ${parentNodeId}`);
  }

  // Step 1: Get upload info via v1.0 storage API
  // SDK: POST /v1.0/storage/spaces/{spaceId}/files/uploadInfos/query?unionId=...
  const ticket = await api(
    `/v1.0/storage/spaces/${spaceId}/files/uploadInfos/query?unionId=${operatorId}`,
    {
      method: 'POST',
      body: JSON.stringify({
        multipart: false,
        protocol: 'HEADER_SIGNATURE',
      }),
    },
  );

  const uploadKey = ticket.uploadKey;
  const sigInfo = ticket.headerSignatureInfo || {};
  const resourceUrls = sigInfo.resourceUrls || [];
  const uploadUrl = resourceUrls[0];
  if (!uploadKey || !uploadUrl) {
    fatal(`No upload URL returned:\n${JSON.stringify(ticket, null, 2)}`);
  }

  // Step 2: Upload file content
  const fileBuffer = fs.readFileSync(filePath);
  const uploadHeaders = {};
  if (sigInfo.headers) {
    for (const [k, v] of Object.entries(sigInfo.headers)) {
      uploadHeaders[k] = v;
    }
  }
  const uploadRes = await fetch(uploadUrl, {
    method: 'PUT',
    headers: uploadHeaders,
    body: fileBuffer,
  });
  if (!uploadRes.ok) {
    fatal(`Upload failed (${uploadRes.status}): ${await uploadRes.text()}`);
  }

  // Step 3: Commit file
  // SDK: POST /v1.0/storage/spaces/{spaceId}/files/commit?unionId=...
  const committed = await api(
    `/v1.0/storage/spaces/${spaceId}/files/commit?unionId=${operatorId}`,
    {
      method: 'POST',
      body: JSON.stringify({
        name: fileName,
        parentId: parentDentryId,
        uploadKey,
      }),
    },
  );

  const dentry = committed.dentry || committed;
  console.log(`Uploaded: ${fileName}`);
  console.log(`  Size: ${fileSize} bytes`);
  if (dentry.id) console.log(`  Dentry ID: ${dentry.id}`);
  if (dentry.spaceId) console.log(`  Space ID: ${dentry.spaceId}`);
}

// ─── Create document in wiki (v2.0 wiki API) ────────────────────────

async function createDocument(parentNodeId, title) {
  const operatorId = await getOperatorId();

  // Get parent node to find workspaceId
  const params = new URLSearchParams({
    withPermissionRole: 'false',
    operatorId,
  });
  const nodeData = await api(`/v2.0/wiki/nodes/${parentNodeId}?${params}`);
  const parentNode = nodeData.node || nodeData;
  const workspaceId = parentNode.workspaceId;
  if (!workspaceId) {
    fatal(`Cannot determine workspaceId for parent node ${parentNodeId}`);
  }

  const data = await api(`/v2.0/wiki/workspaces/${workspaceId}/nodes`, {
    method: 'POST',
    body: JSON.stringify({
      operatorId,
      parentNodeId,
      name: title,
      category: 'ALIDOC',
    }),
  });

  const node = data.node || data;
  console.log(`Created document: ${title}`);
  if (node.nodeId) console.log(`  Node ID: ${node.nodeId}`);
  if (node.docKey) console.log(`  Doc Key: ${node.docKey}`);
  if (node.url) console.log(`  URL: ${node.url}`);
}

// ─── Create folder in wiki (v2.0 wiki API) ──────────────────────────

async function createFolder(parentNodeId, name) {
  const operatorId = await getOperatorId();

  const params = new URLSearchParams({
    withPermissionRole: 'false',
    operatorId,
  });
  const nodeData = await api(`/v2.0/wiki/nodes/${parentNodeId}?${params}`);
  const parentNode = nodeData.node || nodeData;
  const workspaceId = parentNode.workspaceId;
  if (!workspaceId) {
    fatal(`Cannot determine workspaceId for parent node ${parentNodeId}`);
  }

  const data = await api(`/v2.0/wiki/workspaces/${workspaceId}/nodes`, {
    method: 'POST',
    body: JSON.stringify({
      operatorId,
      parentNodeId,
      name,
      category: 'FOLDER',
    }),
  });

  const node = data.node || data;
  console.log(`Created folder: ${name}`);
  if (node.nodeId) console.log(`  Node ID: ${node.nodeId}`);
  if (node.url) console.log(`  URL: ${node.url}`);
}

// ─── Write/append to document (v1.0 doc API) ────────────────────────

async function writeDocument(nodeId, content, append) {
  const operatorId = await getOperatorId();

  // Resolve docKey from node
  const params = new URLSearchParams({
    withPermissionRole: 'false',
    operatorId,
  });
  const nodeData = await api(`/v2.0/wiki/nodes/${nodeId}?${params}`);
  const node = nodeData.node || nodeData;
  const docKey = node.docKey || node.nodeId || nodeId;

  if (append) {
    // Insert blocks at end of document
    // SDK: POST /v1.0/doc/documents/{documentId}/blocks
    await api(`/v1.0/doc/documents/${docKey}/blocks`, {
      method: 'POST',
      body: JSON.stringify({
        operatorId,
        location: { head: false },
        blocks: [{
          blockType: 'PARAGRAPH',
          paragraph: {
            children: [{
              elementType: 'TEXT_RUN',
              text: { content },
            }],
          },
        }],
      }),
    });
    console.log(`Appended content to document ${node.name || nodeId}`);
  } else {
    // Overwrite entire document content
    // SDK: POST /v1.0/doc/suites/documents/{docKey}/overwriteContent?operatorId=...
    await api(
      `/v1.0/doc/suites/documents/${docKey}/overwriteContent?operatorId=${operatorId}`,
      {
        method: 'POST',
        body: JSON.stringify({
          content,
          dataType: 'MARKDOWN',
        }),
      },
    );
    console.log(`Wrote content to document ${node.name || nodeId}`);
  }
}

// ─── Search (v1.0 doc API) ──────────────────────────────────────────

async function searchDocs(keyword, workspaceId) {
  const body = { keyword, maxResults: 20 };
  if (workspaceId) body.workspaceId = workspaceId;
  const data = await api('/v1.0/doc/docs/search', {
    method: 'POST',
    body: JSON.stringify(body),
  });
  const items = data.items || data.docs || [];
  if (!items.length) {
    console.log(`No documents found for "${keyword}".`);
    return;
  }
  console.log(`Search results for "${keyword}":\n`);
  for (const doc of items) {
    console.log(`  ${doc.name || doc.title}`);
    if (doc.nodeId) console.log(`    Node ID: ${doc.nodeId}`);
    if (doc.docKey) console.log(`    Doc key: ${doc.docKey}`);
    if (doc.workspaceId) console.log(`    Workspace: ${doc.workspaceId}`);
    if (doc.nodeType) console.log(`    Type: ${doc.nodeType}`);
    if (doc.url) console.log(`    URL: ${doc.url}`);
    console.log();
  }
}

// ─── CLI ─────────────────────────────────────────────────────────────

function fatal(msg) {
  console.error(`Error: ${msg}`);
  process.exit(1);
}

function usage() {
  console.log(`Usage:
  dingtalk-wiki spaces                              List workspaces (knowledge bases)
  dingtalk-wiki nodes <parent_node_id>              List child nodes (use rootNodeId from spaces)
  dingtalk-wiki read <url_or_node_id>               Read document/file (auto-detects type)
  dingtalk-wiki download <url_or_node_id> [dir]     Download a file to dir (default: .)
  dingtalk-wiki upload <parent_node_id> <file>      Upload a file to a wiki node
  dingtalk-wiki create <parent_node_id> <title>     Create a new document
  dingtalk-wiki mkdir <parent_node_id> <name>       Create a folder
  dingtalk-wiki write <node_id> <text>              Overwrite document content
  dingtalk-wiki append <node_id> <text>             Append to document
  dingtalk-wiki node <url_or_node_id>               Get node info (type, title, IDs)
  dingtalk-wiki search <keyword>                    Search documents by keyword
  dingtalk-wiki search <keyword> -w <workspace_id>  Search within a workspace

Environment:
  DINGTALK_APP_KEY       DingTalk app key (required)
  DINGTALK_APP_SECRET    DingTalk app secret (required)

Note: operatorId (unionId) is auto-resolved from the org's primary admin.`);
  process.exit(0);
}

async function main() {
  const args = process.argv.slice(2);
  if (!args.length) usage();

  const cmd = args[0];

  switch (cmd) {
    case 'spaces':
      await listWorkspaces();
      break;

    case 'nodes': {
      const parentNodeId = args[1];
      if (!parentNodeId) fatal('Usage: dingtalk-wiki nodes <parent_node_id>\n  Use rootNodeId from "dingtalk-wiki spaces" output.');
      await listNodes(parentNodeId);
      break;
    }

    case 'read': {
      const input = args[1];
      if (!input) fatal('Usage: dingtalk-wiki read <url_or_node_id>');
      const parsed = parseUrlOrToken(input);
      await readDocument(parsed.nodeId || input);
      break;
    }

    case 'download': {
      const input = args[1];
      if (!input) fatal('Usage: dingtalk-wiki download <url_or_node_id> [output_dir]');
      const parsed = parseUrlOrToken(input);
      const outputDir = args[2] || '.';
      await downloadFile(parsed.nodeId || input, outputDir);
      break;
    }

    case 'node': {
      const input = args[1];
      if (!input) fatal('Usage: dingtalk-wiki node <url_or_node_id>');
      const parsed = parseUrlOrToken(input);
      await getNode(parsed.nodeId || input);
      break;
    }

    case 'upload': {
      const parentId = args[1];
      const file = args[2];
      if (!parentId || !file) fatal('Usage: dingtalk-wiki upload <parent_node_id> <file_path>');
      await uploadFile(parentId, file);
      break;
    }

    case 'create': {
      const parentId = args[1];
      const title = args[2];
      if (!parentId || !title) fatal('Usage: dingtalk-wiki create <parent_node_id> <title>');
      await createDocument(parentId, title);
      break;
    }

    case 'mkdir': {
      const parentId = args[1];
      const name = args[2];
      if (!parentId || !name) fatal('Usage: dingtalk-wiki mkdir <parent_node_id> <name>');
      await createFolder(parentId, name);
      break;
    }

    case 'write': {
      const nid = args[1];
      const text = args.slice(2).join(' ');
      if (!nid || !text) fatal('Usage: dingtalk-wiki write <node_id> <text>');
      const parsed2 = parseUrlOrToken(nid);
      await writeDocument(parsed2.nodeId || nid, text, false);
      break;
    }

    case 'append': {
      const nid = args[1];
      const text = args.slice(2).join(' ');
      if (!nid || !text) fatal('Usage: dingtalk-wiki append <node_id> <text>');
      const parsed2 = parseUrlOrToken(nid);
      await writeDocument(parsed2.nodeId || nid, text, true);
      break;
    }

    case 'search': {
      const keyword = args[1];
      if (!keyword) fatal('Usage: dingtalk-wiki search <keyword> [-w <workspace_id>]');
      const wIdx = args.indexOf('-w');
      const workspaceId = wIdx !== -1 ? args[wIdx + 1] : undefined;
      await searchDocs(keyword, workspaceId);
      break;
    }

    case 'help':
    case '--help':
    case '-h':
      usage();
      break;

    default:
      fatal(`Unknown command: ${cmd}\nRun "dingtalk-wiki help" for usage.`);
  }
}

main().catch((err) => {
  fatal(err.message || String(err));
});
